# vLLM Dockerfile for Nemotron Omni multimodal deployment
# Based on official vLLM OpenAI image with audio extras
FROM vllm/vllm-openai:v0.20.1

# Install audio extras for video+audio multimodal support
RUN pip install --no-cache-dir "vllm[audio]"

# Additional utilities
RUN pip install --no-cache-dir huggingface_hub hf_transfer

RUN mkdir -p /home/vllm/models /home/vllm/.cache

ENV HF_HUB_ENABLE_HF_TRANSFER=1

COPY scripts/start-vllm.sh /start-vllm.sh
RUN chmod +x /start-vllm.sh

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=300s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

ENTRYPOINT ["/start-vllm.sh"]
