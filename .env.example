# llama.cpp inference image (Deploy page / SDK `docker run`). Build with: docker compose build llamacpp-api
# LLAMACPP_DOCKER_IMAGE=llama-nexus-llamacpp-api:latest
# Docker network for spawned containers — must match compose `networks.default.name` (often {project}_default)
# DOCKER_NETWORK=llama-nexus_default
# Optional override for models volume (otherwise derived from DOCKER_NETWORK)
# LLAMACPP_MODELS_VOLUME=

# llama.cpp Docker build (llamacpp-builder / llamacpp-api image): CMake SM version, e.g. 86 RTX 30xx, 89 RTX 40xx.
# Do not use "native" — docker build has no GPU, so CMake cannot detect SM.
# CUDA_ARCH=86

HUGGINGFACE_TOKEN=ENTER_HF_TOKEN
VITE_API_BASE_URL=http://192.168.1.77:8600  # LlamaCPP API URL
VITE_BACKEND_URL=http://192.168.1.77:8700
N_CPU_MOE=21

# API key for llama.cpp inference and embedding servers
API_KEY=placeholder-api-key
EMBEDDING_SERVICE_API_KEY=llamacpp-embed

# RAG Context Window Expansion
# Include neighboring chunks for better context in similarity search
RAG_CONTEXT_NEIGHBORS_BEFORE=1
RAG_CONTEXT_NEIGHBORS_AFTER=1

# ============================================
# GraphRAG Configuration
# ============================================
# Enable core GraphRAG features (Neo4j + knowledge graph)
GRAPHRAG_ENABLED=false

# Neo4j connection (auto-starts with --profile graphrag)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Optional GPU Services (leave empty to disable)
# Deploy with: docker compose --profile graphrag-ner up -d
# NER_API_URL=http://graphrag-ner:8001

# Deploy with: docker compose --profile graphrag-rel up -d
# REL_API_URL=http://graphrag-rel:8002

# Deploy with: docker compose --profile graphrag-code up -d
# CODE_RAG_URL=http://graphrag-code:8000

# Anthropic API (for advanced reasoning features)
# ANTHROPIC_API_KEY=your_key_here