FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends git python3 python3-pip python3-dev libgomp1 && \
    rm -rf /var/lib/apt/lists/*

# Upgrade pip to support --break-system-packages
RUN pip3 install --upgrade pip

WORKDIR /app

RUN pip3 install --no-cache-dir \
    "lm_eval[api]" \
    redis \
    pydantic \
    httpx \
    transformers \
    requests

# Install llama-cpp-python with CUDA support (pre-built wheel)
RUN pip3 install --no-cache-dir \
    llama-cpp-python \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu121

COPY lm_eval_worker.py /app/lm_eval_worker.py
COPY logprobs_proxy.py /app/logprobs_proxy.py
COPY benchmark_direct.py /app/benchmark_direct.py
COPY benchmark_fast.py /app/benchmark_fast.py

COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
